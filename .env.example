# অ্যাপ ইউআরএল
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ডাটাবেস (SQLite)
DATABASE_URL="file:./dev.db"

# সিকিউরিটি
ADMIN_SECRET="your_random_secret_here"

# ইমেইল কনফিগারেশন (Nodemailer এর জন্য)
